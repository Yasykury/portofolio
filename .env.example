# Copy this file to ".env.local" for local dev, and set the same keys in
# Vercel → Project → Settings → Environment Variables for production.

# Your live domain (used for SEO/social metadata). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://yasykury.com

# Contact form email (Resend — https://resend.com). Without this, the form
# falls back to saving submissions to a local file (dev only).
RESEND_API_KEY=
# Where inquiries are delivered:
CONTACT_TO=yasykury@outlook.com
# Sender. Use onboarding@resend.dev for testing, or an address on a domain
# you've verified in Resend, e.g. "Yasykury <hello@yasykury.com>".
CONTACT_FROM=Portfolio <onboarding@resend.dev>

# Cloudflare Turnstile (bot protection for the contact form — free).
# Get a widget at https://dash.cloudflare.com → Turnstile → Add widget.
# The form only enforces this when BOTH keys are set; otherwise it's a no-op.
# Public site key (safe to expose, ships to the browser):
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Secret key (server-only — never commit the real value):
TURNSTILE_SECRET_KEY=
